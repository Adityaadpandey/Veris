PORT=5000
CAPTURES_PATH=/home/pi/lensmint/captures
NODE_ENV=production

# Optional: override the SQLite database file location
# DATABASE_PATH=/home/pi/lensmint/database/lensmint.db

# Solana (veris Anchor program)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
VERIS_PROGRAM_ID=6beFq5WaWo7dPPEzVNt8gRG1YwJiFyUuhzpH1ydVDd23

# Optional overrides for locating solana-program/{deployment.json,idl/veris.json}
# when this service isn't checked out alongside solana-program/.
# SOLANA_DEPLOYMENT_PATH=/path/to/solana-program/deployment.json
# VERIS_IDL_PATH=/path/to/solana-program/idl/veris.json

# Minimum SOL balance before /api/balance reports the device as needing funding
MIN_SOL_BALANCE=0.05

# Optional: skip camera-app hardware-key auto-extraction and use a fixed
# 32-byte ed25519 seed (64 hex chars) instead.
# DEVICE_SEED_HEX=

# Wallet (base58 Solana address) that receives auto-minted original NFTs
OWNER_WALLET_ADDRESS=

# Filecoin (Lighthouse)
LIGHTHOUSE_API_KEY=

# Public claim server
CLAIM_SERVER_URL=https://lensmint.onrender.com

# Public URL of this hardware-web3-service (used for device verification callbacks)
# e.g. your ngrok URL or a public IP
DEVICE_API_URL=https://your-ngrok-url.ngrok-free.app

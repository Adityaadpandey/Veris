# ── LensMint Claim Server ─────────────────────────────────────────────────
PORT=5001

# Public URLs (must NOT be localhost — used to build claim links)
CLAIM_SERVER_URL=https://lensmint.onrender.com
FRONTEND_URL=https://lensmint.onrender.com

# CORS
CORS_ORIGIN=*

# Database
DATABASE_PATH=./database/claims.db

# IPFS gateway used to fetch/serve images
LIGHTHOUSE_GATEWAY=https://structural-crocodile-le3p6.lighthouseweb3.xyz/ipfs

# ── Gemini AI (descriptions + semantic search embeddings) ──────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=768
GEMINI_TIMEOUT=30000

# Minimum cosine similarity for search / similar-photo matches (0-1)
SEARCH_MIN_SCORE=0.6

# Delay between images during backfill (ms) to respect Gemini rate limits
BACKFILL_DELAY_MS=1500

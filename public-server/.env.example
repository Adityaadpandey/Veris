# ── LensMint Claim Server ─────────────────────────────────────────────────
PORT=5001

# Public URLs (must NOT be localhost — used to build claim links)
CLAIM_SERVER_URL=https://lensmint.onrender.com
FRONTEND_URL=https://lensmint.onrender.com

# CORS
CORS_ORIGIN=*

# Database
DATABASE_PATH=./database/claims.db

# IPFS gateway used to fetch/serve images
LIGHTHOUSE_GATEWAY=https://structural-crocodile-le3p6.lighthouseweb3.xyz/ipfs

# ── Gemini AI (descriptions + semantic search embeddings) ──────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=768
GEMINI_TIMEOUT=30000

# Minimum blended score (0-1) for a photo to appear in the "similar" list.
SEARCH_MIN_SCORE=0.7

# How much the "similar" ranking weights VISUAL look (perceptual hash) vs
# CONTENT/subject (Gemini embedding). 0.7 = 70% visual, 30% content. Higher =
# stricter about actual visual likeness, so "same scene, different angle" drops
# out instead of scoring high on shared subject matter. Range 0-1.
SEARCH_VISUAL_WEIGHT=0.7

# Max perceptual-hash Hamming distance (0-64) for an upload to count as the
# SAME source image (an "altered copy"). Lower = stricter. 10 is a good default.
PHASH_MAX_DISTANCE=10

# Delay between images during backfill (ms) to respect Gemini rate limits
BACKFILL_DELAY_MS=1500
